# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_API_KEY_2 ... GEMINI_API_KEY_9: Additional Gemini keys for automatic round-robin rotation.
# The server will cycle through all configured keys. When one hits a 429 quota limit,
# the next key is tried automatically. Supports up to 9 extra keys.
GEMINI_API_KEY_2=""
GEMINI_API_KEY_3=""

# OPENAI_API_KEY: Optional OpenAI API key utilized as a failover/fallback provider 
# if Gemini encounters quota limit constraints (such as 429 rate-limiting).
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# Optional provider model overrides.
GEMINI_MODEL="gemini-2.5-flash"
OPENAI_MODEL="gpt-4o"

# Optional AI timeout guards to avoid HTTP 504 on hosted deployments.
AI_SEARCH_TIMEOUT_MS=7000
AI_OPINION_TIMEOUT_MS=22000
AI_OCR_TIMEOUT_MS=40000
OPENAI_FETCH_TIMEOUT_MS=45000

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE KEYS: Connect standard Supabase services (Client-side exposed)
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# SMTP EMAIL CLIENT CONFIG (Optional, falls back to simulated dispatch if empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=
